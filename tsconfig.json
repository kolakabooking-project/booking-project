{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "isolatedModules": true
  },
  "include": ["api/**/*.ts", "server/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
