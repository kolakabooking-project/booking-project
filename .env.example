# ═══════════════════════════════════════════════════════════
#  BOOKOLAKA — Environment Variables
#  Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════

# ─── NeonDB (PostgreSQL) ───
# Get your connection string from https://neon.tech/dashboard
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.neon.tech/bookolaka?sslmode=require

# ─── Server ───
PORT=3001
NODE_ENV=production

# ─── CORS Origins ───
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-app.vercel.app

# ─── Better Auth ───
# Generate with: openssl rand -base64 64
BETTER_AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
BETTER_AUTH_URL=https://your-app.vercel.app

# ─── Ably Realtime ───
ABLY_API_KEY=your_ably_root_api_key_here

# ─── Chat Encryption ───
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── File Upload ───
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=1
