# ═══════════════════════════════════════════════════════════
#  BOOKOLAKA Server — Local Development Environment
#  Copy this file to .env for local development
# ═══════════════════════════════════════════════════════════

# ─── Database ───
# Local PostgreSQL for development
DATABASE_URL=postgresql://mac@localhost:5432/bookolaka

# ─── Server ───
PORT=3001
NODE_ENV=development

# ─── CORS — comma-separated origins ───
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3030

# ─── Better Auth ───
# For production: generate with `openssl rand -base64 64`
BETTER_AUTH_SECRET=dev-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3001

# ─── File Upload ───
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=1

# ─── Ably Realtime ───
ABLY_API_KEY=your_ably_root_api_key_here

# ─── Chat Encryption ───
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_character_encryption_key_here_replace_me_now_please
